# DreamLog 环境配置

# ==================== 应用配置 ====================
APP_NAME=DreamLog Web
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./data/dreamlog.db

# ==================== AI 服务配置 ====================
# 大语言模型 API (用于梦境解析)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# 图像生成 API (用于梦境可视化)
IMAGE_GEN_PROVIDER=openai
IMAGE_GEN_API_KEY=
IMAGE_GEN_MODEL=dall-e-3

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=8000

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_PATH=./data/logs
